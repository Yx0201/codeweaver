generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String?
  email          String           @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  accounts       Account[]
  conversations  conversation[]
  knowledgeBases knowledge_base[]
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model conversation {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String?
  search_mode       String?                @default("hybrid") @db.VarChar(20)
  created_at        DateTime?              @default(now()) @db.Timestamp(6)
  updated_at        DateTime?              @default(now()) @db.Timestamp(6)
  knowledge_base_id Int?
  user_id           String?                @db.Uuid
  messages          conversation_message[]
  knowledge_base    knowledge_base?        @relation(fields: [knowledge_base_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  user              User?                  @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([knowledge_base_id], map: "idx_conversation_kbid")
  @@index([user_id], map: "idx_conversation_user_id")
}

model conversation_message {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String       @db.Uuid
  role            String       @db.VarChar(50)
  content         String
  // Per-message structured payload. For assistant messages we store the
  // retrieved RAG references (index → chunk_id, file_id, filename, snippet,
  // chunk_text) so the citation UI survives a page refresh.
  metadata        Json?
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  conversation    conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id], map: "idx_conv_msg_conversation_id")
}

model document_chunks {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  file_id         String                 @db.Uuid
  chunk_text      String
  embedding       Unsupported("vector(1024)")?
  keywords        Unsupported("tsvector")?
  chunk_order     Int?
  metadata        Json?
  created_at      DateTime?              @default(now()) @db.Timestamp(6)
  parent_chunk_id String?                @db.Uuid
  chunk_type      String?                @db.VarChar(20)
  uploaded_files  uploaded_files         @relation(fields: [file_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent_chunk    document_chunks?       @relation("ParentChild", fields: [parent_chunk_id], references: [id], onDelete: Cascade)
  child_chunks    document_chunks[]      @relation("ParentChild")

  @@index([file_id], map: "idx_document_chunks_file_id")
  @@index([parent_chunk_id], map: "idx_document_chunks_parent_id")
}

model graph_chunks {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  file_id        String          @db.Uuid
  chunk_text     String
  chunk_order    Int?
  chapter_title  String?         @db.VarChar(255)
  volume_title   String?         @db.VarChar(255)
  metadata       Json?
  created_at     DateTime?       @default(now()) @db.Timestamp(6)
  uploaded_files uploaded_files  @relation(fields: [file_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  entity_chunks  kg_entity_chunk[]

  @@index([file_id], map: "idx_graph_chunks_file_id")
}

model kg_entity {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledge_base_id Int
  name              String        @db.VarChar(500)
  entity_type       String        @db.VarChar(50)
  description       String?
  name_embedding    Unsupported("vector(1024)")?
  name_keywords     Unsupported("tsvector")?
  metadata          Json?
  created_at        DateTime?     @default(now()) @db.Timestamp(6)
  source_relations  kg_relation[] @relation("SourceEntity")
  target_relations  kg_relation[] @relation("TargetEntity")
  entity_chunks     kg_entity_chunk[]

  @@index([knowledge_base_id], map: "idx_kg_entity_kbid")
  @@index([name], map: "idx_kg_entity_name")
}

model kg_relation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledge_base_id Int
  source_entity_id  String    @db.Uuid
  target_entity_id  String    @db.Uuid
  relation_type     String    @db.VarChar(200)
  description       String?
  metadata          Json?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  source_entity     kg_entity @relation("SourceEntity", fields: [source_entity_id], references: [id], onDelete: Cascade)
  target_entity     kg_entity @relation("TargetEntity", fields: [target_entity_id], references: [id], onDelete: Cascade)

  @@index([knowledge_base_id], map: "idx_kg_relation_kbid")
  @@index([source_entity_id], map: "idx_kg_relation_source")
  @@index([target_entity_id], map: "idx_kg_relation_target")
}

model kg_entity_chunk {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_id  String       @db.Uuid
  chunk_id   String       @db.Uuid
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  entity     kg_entity    @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  chunk      graph_chunks @relation(fields: [chunk_id], references: [id], onDelete: Cascade)

  @@unique([entity_id, chunk_id], map: "idx_kg_entity_chunk_unique")
  @@index([entity_id], map: "idx_kg_ec_entity")
  @@index([chunk_id], map: "idx_kg_ec_chunk")
}

model knowledge_base {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(255)
  description    String?
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  user_id        String?          @db.Uuid
  uploaded_files uploaded_files[]
  conversations  conversation[]
  user           User?            @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id], map: "idx_kb_user_id")
}

model uploaded_files {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledge_base_id Int
  filename          String            @db.VarChar(500)
  original_path     String?
  file_size         BigInt?
  upload_time       DateTime?         @default(now()) @db.Timestamp(6)
  status            String?           @default("uploaded") @db.VarChar(50)
  metadata          Json?
  // 上传原文(二进制)所在的 Vercel Blob URL。检索/分块所需的文本仍由
  // `content` 提供;file_data 仅供存量数据迁移过渡使用,迁移完成后移除。
  blob_url          String?           @db.VarChar(1000)
  content           String?
  file_data         Bytes?
  mime_type         String?           @db.VarChar(255)
  document_chunks   document_chunks[]
  graph_chunks      graph_chunks[]
  knowledge_base    knowledge_base    @relation(fields: [knowledge_base_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([knowledge_base_id], map: "idx_uploaded_files_kbid")
}
